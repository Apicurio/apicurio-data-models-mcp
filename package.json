{
    "name": "@apicurio/data-models-mcp",
    "version": "0.1.0",
    "description": "MCP server wrapping @apicurio/data-models for AI-assisted OpenAPI and AsyncAPI editing",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "apicurio-data-models-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "biome check src test",
        "lint:fix": "biome check --fix src test"
    },
    "keywords": [
        "mcp",
        "openapi",
        "asyncapi",
        "apicurio",
        "data-models"
    ],
    "license": "Apache-2.0",
    "dependencies": {
        "@apicurio/data-models": "2.5.0",
        "@modelcontextprotocol/sdk": "1.27.1",
        "js-yaml": "4.1.1",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.5",
        "@types/js-yaml": "4.0.9",
        "@types/node": "22.19.13",
        "typescript": "5.9.3",
        "vitest": "3.2.4"
    }
}
